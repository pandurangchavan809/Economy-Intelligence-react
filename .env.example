# CountryLayer API (REQUIRED)
COUNTRYLAYER_API_KEY=

# World Bank (public – keep empty)
WORLD_BANK_API_KEY=

# IMF (public – keep empty)
IMF_API_KEY=

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=economy_intelligence
DB_SSL_DISABLED=false

# Gemini api key 
GEMINI_API_KEY=.....
GEMINI_MODEL=gemini-2.5-flash

# Flask app
FLASK_PORT=5000
FLASK_DEBUG=true
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://economic-intelligence.vercel.app

# Admin login
ADMIN_ID=admin
ADMIN_PASS=admin123
JWT_SECRET=change-this-secret
JWT_EXPIRES_HOURS=12
