# CountryLayer API (REQUIRED)
COUNTRYLAYER_API_KEY=

# World Bank (public – keep empty)
WORLD_BANK_API_KEY=

# IMF (public – keep empty)
IMF_API_KEY=

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=economy_intelligence
DB_SSL_DISABLED=false
DB_POOL_NAME=economy_intelligence_pool
DB_POOL_SIZE=5
DB_CONNECTION_TIMEOUT=5

# Gemini api key 
GEMINI_API_KEY=.....
GEMINI_MODEL=gemini-2.5-flash
FX_API_URL=https://api.exchangerate-api.com/v4/latest/USD
FX_REQUEST_TIMEOUT_SECONDS=3
FX_CACHE_TTL_SECONDS=21600

# Flask app
FLASK_PORT=5000
FLASK_DEBUG=true
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://economic-intelligence.vercel.app

# Admin login
ADMIN_ID=admin
ADMIN_PASS=admin123
JWT_SECRET=change-this-secret
JWT_EXPIRES_HOURS=12
